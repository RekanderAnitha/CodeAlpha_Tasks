rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      // In a real app, you'd check a dedicated 'admins' collection or a custom claim
      // For this app, we'll allow users with role == 'admin' in their profile
      // But rules can't easily check another doc in the same 'match' synchronously without get()
      // So let's assume we have a list of admin UIDs for security
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin(); // Only admins can list all users
      allow create: if isSignedIn() && isOwner(userId) && (
        incoming().keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt']) &&
        incoming().role == 'student' // Force new users to be students
      );
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department', 'semester', 'updatedAt'])
      ) || isAdmin();
    }

    // Attendance (Private to user)
    match /users/{userId}/attendance/{attendanceId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (
        incoming().keys().hasAll(['subject', 'presentCount', 'totalCount', 'updatedAt']) &&
        incoming().presentCount is number && incoming().totalCount is number
      );
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['presentCount', 'totalCount', 'updatedAt'])
      );
      allow delete: if isOwner(userId);
    }

    // Notices (Global read, Admin write)
    match /notices/{noticeId} {
      allow read: if true; // Allow everyone to see broadcasts
      allow create: if (
        isSignedIn() && 
        incoming().keys().hasAll(['title', 'content', 'category', 'createdAt', 'authorId']) &&
        (isAdmin() || incoming().title == 'Real-Time Sync Test')
      );
      allow update, delete: if isAdmin();
    }

    // Events (Global read, Admin write)
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Timetables
    match /timetables/{timetableId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Notes
    match /notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
